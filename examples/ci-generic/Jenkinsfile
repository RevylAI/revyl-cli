// Jenkins Declarative Pipeline -- Revyl test pipeline
//
// Add REVYL_API_KEY as a credential in Jenkins (Secret text).

pipeline {
    agent any

    environment {
        REVYL_API_KEY = credentials('revyl-api-key')
        REVYL_INSTALL_DIR = '/usr/local/bin'
    }

    stages {
        stage('Install') {
            steps {
                sh '''
                    if command -v curl >/dev/null 2>&1; then
                        curl -fsSL https://raw.githubusercontent.com/RevylAI/revyl-cli/main/scripts/install.sh | sh
                    elif command -v wget >/dev/null 2>&1; then
                        wget -qO- https://raw.githubusercontent.com/RevylAI/revyl-cli/main/scripts/install.sh | sh
                    else
                        echo "ERROR: curl or wget is required to install Revyl CLI" >&2
                        exit 1
                    fi
                '''
            }
        }

        // Optional: build and upload
        // stage('Build & Upload') {
        //     steps {
        //         sh './gradlew assembleDebug'
        //         sh 'revyl build upload --file ./app.apk --app your-app-id --set-current'
        //     }
        // }

        // Blocking: waits for tests to complete
        stage('Test') {
            steps {
                sh 'revyl workflow run smoke-tests'
            }
        }

        // Fire-and-forget alternative: uncomment to use instead of blocking Test stage
        // stage('Queue Tests') {
        //     steps {
        //         sh 'revyl workflow run smoke-tests --no-wait'
        //     }
        // }
        // stage('Check Status') {
        //     steps {
        //         sh 'revyl workflow status smoke-tests --json'
        //     }
        // }
    }

    post {
        failure {
            echo 'Revyl tests failed'
        }
    }
}
