{
  "mcpServers": {
    "revyl": {
      "type": "stdio",
      "command": "${CURSOR_PLUGIN_ROOT}/hooks/launch-revyl",
      "args": ["mcp", "serve", "--profile", "dev"],
      "env": {
        "REVYL_PROJECT_DIR": "${workspaceFolder}",
        "REVYL_API_KEY": "${env:REVYL_API_KEY}",
        "REVYL_BINARY": "${env:REVYL_BINARY}"
      },
      "_meta": {
        "ideToolIconPath": "./assets/icon.svg"
      }
    }
  }
}
